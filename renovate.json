{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":rebaseStalePrs",
    "group:allNonMajor",
    "schedule:weekly"
  ],
  "labels": [
    "dependencies"
  ],
  "timezone": "Europe/Warsaw",
  "rangeStrategy": "bump",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "_prHourlyLimit_intent": "per-repo limit, not org-aggregate",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 6am on monday"
    ],
    "automerge": true
  },
  "vulnerabilityAlerts": {
    "labels": [
      "security",
      "vulnerability"
    ],
    "automerge": false
  },
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchPackageNames": [
        "sqlx"
      ],
      "matchUpdateTypes": [
        "major",
        "minor"
      ],
      "matchCurrentVersion": ">=0.8.0",
      "enabled": false
    }
  ]
}
